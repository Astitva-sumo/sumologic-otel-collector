{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["group:all"],
  "packageRules": [
    {
      "matchPackageNames": [".*"],
      "enabled": false
    },
    {
      "matchPackageNames": [
        "^go.opentelemetry.io/collector.*",
        "^github.com/open-telemetry/opentelemetry-collector-contrib.*"
      ],
      "groupName": "opentelemetry-collector"
    }
  ]
}
